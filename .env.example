# OpenAI / Claude / Llama API keys
OPENAI_API_KEY=changeme
ANTHROPIC_API_KEY=changeme
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
GOOGLE_VERTEX_ENDPOINT=
GOOGLE_VERTEX_KEY=

# Application
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Persistent memory path inside the container
OPENCLAW_DATA_DIR=/var/lib/openclaw

# Optional proxy (Nginx terminates TLS)
EXTERNAL_URL=https://your-domain.example

# Monitoring toggle for Netdata cloud (optional)
NETDATA_CLAIM_TOKEN=
NETDATA_CLAIM_ROOMS=
NETDATA_CLAIM_URL=https://app.netdata.cloud
